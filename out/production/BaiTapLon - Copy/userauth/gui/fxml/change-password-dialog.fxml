<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.PasswordField?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.StackPane?>
<?import javafx.scene.layout.VBox?>

<StackPane maxHeight="-Infinity" maxWidth="-Infinity" minHeight="-Infinity" minWidth="-Infinity"
           prefHeight="340.0" prefWidth="460.0"
           fx:controller="userauth.gui.fxml.ChangePasswordDialogController"
           styleClass="dialog-root"
           stylesheets="@auth-theme.css"
           xmlns="http://javafx.com/javafx/21"
           xmlns:fx="http://javafx.com/fxml/1">
    <children>
        <VBox maxWidth="416.0" prefWidth="416.0" spacing="16.0" styleClass="dialog-card">
            <children>
                <Label text="CHANGE PASSWORD" styleClass="section-title"/>
                <Label fx:id="lblUsername" text="Account: -" styleClass="body-text"/>
                <VBox spacing="10.0">
                    <children>
                        <Label text="Current Password" styleClass="field-label"/>
                        <PasswordField fx:id="txtOldPassword" promptText="Enter current password"/>
                        <Label text="New Password" styleClass="field-label"/>
                        <PasswordField fx:id="txtNewPassword" onAction="#handleSubmit" promptText="Enter new password"/>
                    </children>
                </VBox>
                <Label fx:id="lblError" managed="false" text="Error message" visible="false" wrapText="true" styleClass="error-text"/>
                <HBox spacing="10.0" styleClass="dialog-actions">
                    <children>
                        <Button mnemonicParsing="false" onAction="#handleCancel" text="CANCEL" styleClass="button ghost-button"/>
                        <Button mnemonicParsing="false" onAction="#handleSubmit" text="UPDATE" styleClass="button primary-button"/>
                    </children>
                </HBox>
            </children>
        </VBox>
    </children>
</StackPane>
