<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.TableColumn?>
<?import javafx.scene.control.TableView?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.StackPane?>
<?import javafx.scene.layout.VBox?>
<?import javafx.scene.shape.Circle?>

<StackPane maxHeight="Infinity" maxWidth="Infinity"
           prefHeight="740.0" prefWidth="1160.0"
           fx:controller="userauth.gui.fxml.BidderDashboardViewController"
           styleClass="page-root"
           stylesheets="@auth-theme.css"
           xmlns="http://javafx.com/javafx/21"
           xmlns:fx="http://javafx.com/fxml/1">
    <children>
        <VBox maxHeight="Infinity" maxWidth="Infinity" prefHeight="692.0" prefWidth="1112.0" spacing="14.0">
            <children>
                <StackPane minWidth="320.0" prefWidth="1112.0" styleClass="hero-card">
                    <children>
                        <Circle fill="WHITE" opacity="0.10" radius="110.0" stroke="TRANSPARENT" translateX="48.0" translateY="-34.0"/>
                        <Circle fill="#9fb4c2" opacity="0.16" radius="84.0" stroke="TRANSPARENT" translateX="-34.0" translateY="40.0"/>
                        <VBox maxWidth="560.0" spacing="14.0">
                            <children>
                                <Label text="LIVE AUCTION HUB" styleClass="hero-badge"/>
                                <Label text="TRUNG TAM DAU GIA" wrapText="true" styleClass="hero-title"/>
                                <Label text="Theo doi phien dau gia, dat gia nhanh va xem lich su giao dich theo thoi gian thuc."
                                       wrapText="true"
                                       styleClass="hero-subtitle"/>
                            </children>
                        </VBox>
                    </children>
                </StackPane>
                <VBox spacing="14.0" VBox.vgrow="ALWAYS">
                    <children>
                        <VBox spacing="16.0" styleClass="form-card" VBox.vgrow="ALWAYS">
                            <children>
                                <Label text="DANH SACH PHIEN DAU GIA" styleClass="section-title"/>
                                <TableView fx:id="tableAuctions" prefHeight="500.0" VBox.vgrow="ALWAYS">
                                    <columns>
                                        <TableColumn fx:id="colId" prefWidth="70.0" text="ID"/>
                                        <TableColumn fx:id="colName" prefWidth="220.0" text="Ten SP"/>
                                        <TableColumn fx:id="colCategory" prefWidth="180.0" text="Danh muc"/>
                                        <TableColumn fx:id="colHighestBid" prefWidth="160.0" text="Gia cao nhat"/>
                                        <TableColumn fx:id="colStatus" prefWidth="140.0" text="Trang thai"/>
                                        <TableColumn fx:id="colTimeLeft" prefWidth="180.0" text="Con lai"/>
                                    </columns>
                                </TableView>
                            </children>
                        </VBox>
                        <HBox alignment="CENTER_LEFT" spacing="10.0">
                            <children>
                                <Button mnemonicParsing="false" onAction="#handlePlaceBid" text="DAT GIA" styleClass="button primary-button"/>
                                <Button mnemonicParsing="false" onAction="#handleShowHistory" text="XEM LICH SU BID" styleClass="button success-button"/>
                                <Button mnemonicParsing="false" onAction="#handleChangePassword" text="DOI MAT KHAU" styleClass="button success-button"/>
                                <Button mnemonicParsing="false" onAction="#handleLogout" text="DANG XUAT" styleClass="button ghost-button"/>
                            </children>
                        </HBox>
                    </children>
                </VBox>
            </children>
        </VBox>
    </children>
</StackPane>
