<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.chart.LineChart?>
<?import javafx.scene.chart.NumberAxis?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.ComboBox?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.MenuButton?>
<?import javafx.scene.control.MenuItem?>
<?import javafx.scene.control.ScrollPane?>
<?import javafx.scene.control.SeparatorMenuItem?>
<?import javafx.scene.control.TableColumn?>
<?import javafx.scene.control.TableView?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.image.ImageView?>
<?import javafx.scene.layout.FlowPane?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.Region?>
<?import javafx.scene.layout.StackPane?>
<?import javafx.scene.layout.VBox?>
<StackPane maxHeight="Infinity" maxWidth="Infinity" prefHeight="960.0" prefWidth="1480.0" styleClass="page-root dashboard-root" stylesheets="@auth-theme.css" xmlns="http://javafx.com/javafx/25" xmlns:fx="http://javafx.com/fxml/1" fx:controller="userauth.gui.fxml.BidderDashboardViewController">
    <children>
        <HBox maxHeight="Infinity" maxWidth="Infinity" spacing="20.0" styleClass="shell-frame">
            <children>
                <VBox minWidth="248.0" prefWidth="248.0" spacing="18.0" styleClass="sidebar-surface">
                    <children>
                        <VBox spacing="6.0">
                            <children>
                                <Label styleClass="sidebar-brand-title" text="AUCTION HOUSE" />
                            </children>
                        </VBox>
                        <VBox spacing="10.0">
                            <children>
                                <Label styleClass="sidebar-nav-title" text="MODULES" />
                                <Label maxWidth="Infinity" styleClass="sidebar-nav-item sidebar-nav-item-active" text="Live Auctions" />
                                <Label maxWidth="Infinity" styleClass="sidebar-nav-item" text="Bid History" />
                            </children>
                        </VBox>
                        <Region VBox.vgrow="ALWAYS" />
                        <VBox spacing="6.0">
                            <children>
                                <Label styleClass="sidebar-nav-title" text="USER SESSION" />
                                <Label fx:id="lblSidebarUser" maxWidth="Infinity" styleClass="sidebar-foot-title" text="Bidder" textOverrun="ELLIPSIS" />
                            </children>
                        </VBox>
                    </children>
                </VBox>
                <VBox spacing="18.0" HBox.hgrow="ALWAYS">
                    <children>
                        <VBox spacing="14.0" styleClass="topbar-surface">
                            <children>
                                <HBox alignment="CENTER_LEFT" spacing="16.0">
                                    <children>
                                        <VBox spacing="4.0" HBox.hgrow="ALWAYS">
                                            <children>
                                                <Label styleClass="topbar-title" text="Bidder Dashboard" />
                                                <Label styleClass="topbar-subtitle" text="Search auctions, inspect details, and place bids quickly." wrapText="true" />
                                            </children>
                                        </VBox>
                                        <VBox minWidth="240.0" prefWidth="260.0" spacing="2.0" styleClass="user-pill bidder-user-pill">
                                            <children>
                                                <Label fx:id="lblUserName" maxWidth="Infinity" styleClass="user-name" text="Bidder" textOverrun="ELLIPSIS" />
                                                <Label styleClass="user-role" text="Role: BIDDER" />
                                            </children>
                                        </VBox>
                                        <MenuButton mnemonicParsing="false" styleClass="button settings-menu-button" text="SETTINGS">
                                            <items>
                                                <MenuItem mnemonicParsing="false" onAction="#handleSwitchToEnglish" text="English" />
                                                <MenuItem mnemonicParsing="false" onAction="#handleSwitchToVietnamese" text="Vietnamese" />
                                                <SeparatorMenuItem />
                                                <MenuItem mnemonicParsing="false" onAction="#handleLogout" text="LOG OUT" />
                                            </items>
                                        </MenuButton>
                                    </children>
                                </HBox>
                                <FlowPane hgap="12.0" prefWrapLength="980.0" vgap="12.0">
                                    <children>
                                        <HBox alignment="CENTER_LEFT" minWidth="340.0" prefWidth="480.0" spacing="10.0" styleClass="search-box bidder-toolbar-search">
                                            <children>
                                                <Label styleClass="field-label" text="SEARCH" />
                                                <TextField fx:id="txtSearch" maxWidth="Infinity" prefWidth="360.0" promptText="Search by product name or category" styleClass="search-field" HBox.hgrow="ALWAYS" />
                                            </children>
                                        </HBox>
                                        <VBox prefWidth="220.0" spacing="4.0" styleClass="bidder-filter-box">
                                            <children>
                                                <Label styleClass="field-label" text="STATUS FILTER" />
                                                <ComboBox fx:id="cbStatusFilter" prefWidth="220.0" />
                                            </children>
                                        </VBox>
                                    </children>
                                </FlowPane>
                            </children>
                        </VBox>
                        <ScrollPane fitToWidth="true" hbarPolicy="NEVER" styleClass="dashboard-scroll" VBox.vgrow="ALWAYS">
                            <content>
                                <VBox spacing="20.0">
                                    <children>
                                        <VBox spacing="12.0" styleClass="hero-banner hero-banner-dark">
                                            <children>
                                                <Label styleClass="dashboard-eyebrow" text="LIVE BIDDING FLOOR" />
                                                <Label styleClass="dashboard-title" text="Bidder Workspace" wrapText="true" />
                                                <Label styleClass="dashboard-copy" text="Track auctions, review live details, and bid without switching screens." wrapText="true" />
                                            </children>
                                        </VBox>
                                        <HBox spacing="14.0">
                                            <children>
                                                <VBox prefWidth="0.0" spacing="8.0" styleClass="metric-card" HBox.hgrow="ALWAYS">
                                                    <children>
                                                        <Label styleClass="metric-label" text="RUNNING AUCTIONS" />
                                                        <Label fx:id="lblRunningCount" styleClass="metric-value" text="0" />
                                                    </children>
                                                </VBox>
                                                <VBox prefWidth="0.0" spacing="8.0" styleClass="metric-card" HBox.hgrow="ALWAYS">
                                                    <children>
                                                        <Label styleClass="metric-label" text="ENDING SOON" />
                                                        <Label fx:id="lblEndingSoonCount" styleClass="metric-value" text="0" />
                                                    </children>
                                                </VBox>
                                                <VBox prefWidth="0.0" spacing="8.0" styleClass="metric-card" HBox.hgrow="ALWAYS">
                                                    <children>
                                                        <Label styleClass="metric-label" text="YOU ARE LEADING" />
                                                        <Label fx:id="lblLeadingCount" styleClass="metric-value" text="0" />
                                                    </children>
                                                </VBox>
                                            </children>
                                        </HBox>
                                        <HBox alignment="TOP_LEFT" spacing="18.0">
                                            <children>
                                                <VBox spacing="18.0" HBox.hgrow="ALWAYS">
                                                    <children>
                                                        <VBox spacing="16.0" styleClass="panel-card">
                                                            <children>
                                                                <VBox spacing="12.0">
                                                                    <children>
                                                                        <VBox spacing="4.0">
                                                                            <children>
                                                                                <Label styleClass="panel-title" text="AUCTION LIST" />
                                                                            </children>
                                                                        </VBox>
                                                                        <FlowPane hgap="10.0" prefWrapLength="900.0" vgap="10.0">
                                                                            <children>
                                                                                <Button minWidth="138.0" mnemonicParsing="false" onAction="#handleShowHistory" styleClass="button ghost-button" text="BID HISTORY" />
                                                                                <Button minWidth="158.0" mnemonicParsing="false" onAction="#handleChangePassword" styleClass="button ghost-button" text="CHANGE PASSWORD" />
                                                                            </children>
                                                                        </FlowPane>
                                                                    </children>
                                                                </VBox>
                                                                <TableView fx:id="tableAuctions" prefHeight="430.0" VBox.vgrow="ALWAYS">
                                                                    <columns>
                                                                        <TableColumn fx:id="colId" prefWidth="70.0" text="ID" />
                                                                        <TableColumn fx:id="colName" prefWidth="240.0" text="Item" />
                                                                        <TableColumn fx:id="colCategory" prefWidth="170.0" text="Category" />
                                                                        <TableColumn fx:id="colHighestBid" prefWidth="160.0" text="Highest Bid" />
                                                                        <TableColumn fx:id="colStatus" prefWidth="140.0" text="Status" />
                                                                        <TableColumn fx:id="colTimeLeft" prefWidth="190.0" text="Remaining" />
                                                                    </columns>
                                                                </TableView>
                                                            </children>
                                                        </VBox>
                                                        <VBox spacing="12.0" styleClass="panel-card chart-card">
                                                            <children>
                                                                <Label styleClass="panel-title" text="PRICE OVER TIME" />
                                                                <LineChart fx:id="chartBidTrend" animated="true" createSymbols="true" legendVisible="false" prefHeight="260.0">
                                                                    <xAxis>
                                                                        <NumberAxis forceZeroInRange="false" label="Bid count" fx:id="xAxisBidTrend" />
                                                                    </xAxis>
                                                                    <yAxis>
                                                                        <NumberAxis fx:id="yAxisBidTrend" forceZeroInRange="false" label="Price" />
                                                                    </yAxis>
                                                                </LineChart>
                                                            </children>
                                                        </VBox>
                                                    </children>
                                                </VBox>
                                                <VBox minWidth="390.0" prefWidth="420.0" spacing="16.0" styleClass="bidder-side-column">
                                                    <children>
                                                        <VBox spacing="14.0" styleClass="detail-card">
                                                            <children>
                                                                <Label styleClass="detail-kicker" text="AUCTION DETAIL" />
                                                                <StackPane maxWidth="Infinity" minHeight="220.0" prefHeight="220.0" styleClass="auction-image-panel detail-image-frame">
                                                                    <children>
                                                                        <ImageView fx:id="imgDetailAuction" fitHeight="220.0" fitWidth="376.0" pickOnBounds="true" preserveRatio="true" smooth="true" styleClass="auction-product-image" />
                                                                        <Label fx:id="lblDetailImageInitial" styleClass="auction-image-initial detail-image-initial" text="A" />
                                                                    </children>
                                                                </StackPane>
                                                                <Label fx:id="lblDetailName" styleClass="detail-product-name" text="Select an auction to view details" wrapText="true" />
                                                                <Label fx:id="lblDetailDescription" styleClass="body-text" text="The product description will appear here." wrapText="true" />
                                                                <Label fx:id="lblDetailCurrentBid" styleClass="detail-price" text="0" />
                                                                <FlowPane hgap="10.0" prefWrapLength="360.0" vgap="10.0">
                                                                    <children>
                                                                        <Label fx:id="lblDetailState" styleClass="status-chip status-chip-neutral" text="Status" />
                                                                        <Label fx:id="lblDetailTimeLeft" styleClass="status-chip status-chip-live" text="Remaining: -" />
                                                                    </children>
                                                                </FlowPane>
                                                                <HBox spacing="12.0">
                                                                    <children>
                                                                        <VBox spacing="4.0" styleClass="detail-meta-box" HBox.hgrow="ALWAYS">
                                                                            <children>
                                                                                <Label styleClass="detail-meta-label" text="STARTING PRICE" />
                                                                                <Label fx:id="lblDetailStartPrice" styleClass="detail-meta-value" text="-" wrapText="true" />
                                                                            </children>
                                                                        </VBox>
                                                                        <VBox spacing="4.0" styleClass="detail-meta-box" HBox.hgrow="ALWAYS">
                                                                            <children>
                                                                                <Label styleClass="detail-meta-label" text="LEADING BIDDER" />
                                                                                <Label fx:id="lblDetailLeader" styleClass="detail-meta-value" text="-" wrapText="true" />
                                                                            </children>
                                                                        </VBox>
                                                                    </children>
                                                                </HBox>
                                                                <VBox spacing="4.0" styleClass="detail-meta-box">
                                                                    <children>
                                                                        <Label styleClass="detail-meta-label" text="SCHEDULE" />
                                                                        <Label fx:id="lblDetailSchedule" styleClass="detail-meta-value" text="-" wrapText="true" />
                                                                    </children>
                                                                </VBox>
                                                                <VBox spacing="4.0" styleClass="detail-meta-box">
                                                                    <children>
                                                                        <Label styleClass="detail-meta-label" text="CATEGORY" />
                                                                        <Label fx:id="lblDetailCategory" styleClass="detail-meta-value" text="-" wrapText="true" />
                                                                    </children>
                                                                </VBox>
                                                            </children>
                                                        </VBox>
                                                        <VBox spacing="12.0" styleClass="detail-card quick-bid-box">
                                                            <children>
                                                                <Label styleClass="panel-title" text="QUICK BID" />
                                                                <TextField fx:id="txtBidAmount" onAction="#handlePlaceBid" promptText="Example: 1500000" />
                                                                <Label fx:id="lblBidStatus" styleClass="secondary-text" text="Bid status information will appear here." wrapText="true" />
                                                                <Button maxWidth="Infinity" mnemonicParsing="false" onAction="#handlePlaceBid" styleClass="button primary-button" text="PLACE BID NOW" />
                                                            </children>
                                                        </VBox>
                                                        <VBox spacing="12.0" styleClass="panel-card">
                                                            <children>
                                                                <HBox alignment="CENTER_LEFT" spacing="10.0">
                                                                    <children>
                                                                        <Label styleClass="panel-title" text="LIVE BID FEED" />
                                                                        <Region HBox.hgrow="ALWAYS" />
                                                                        <Label fx:id="lblLiveBidCount" styleClass="secondary-text" text="0 transactions" />
                                                                    </children>
                                                                </HBox>
                                                                <VBox fx:id="bidsLiveContainer" spacing="10.0" />
                                                            </children>
                                                        </VBox>
                                                    </children>
                                                </VBox>
                                            </children>
                                        </HBox>
                                    </children>
                                </VBox>
                            </content>
                        </ScrollPane>
                    </children>
                </VBox>
            </children>
        </HBox>
    </children>
</StackPane>
