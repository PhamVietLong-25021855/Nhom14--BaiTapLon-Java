<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.collections.FXCollections?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.ComboBox?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.PasswordField?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.StackPane?>
<?import javafx.scene.layout.VBox?>
<?import javafx.scene.shape.Circle?>
<?import javafx.scene.shape.SVGPath?>
<?import javafx.scene.paint.Color?>
<?import java.lang.String?>

<StackPane maxHeight="Infinity" maxWidth="Infinity"
           prefHeight="760.0" prefWidth="1060.0"
           fx:controller="userauth.gui.fxml.RegisterViewController"
           styleClass="page-root"
           stylesheets="@auth-theme.css"
           xmlns="http://javafx.com/javafx/21"
           xmlns:fx="http://javafx.com/fxml/1">
    <children>
        <HBox maxHeight="Infinity" maxWidth="Infinity" prefHeight="712.0" prefWidth="1012.0" spacing="18.0" styleClass="content-row">
            <children>
                <StackPane HBox.hgrow="ALWAYS" minWidth="320.0" prefWidth="474.0" styleClass="hero-card">
                    <children>
                        <Circle fill="WHITE" opacity="0.10" radius="110.0" stroke="TRANSPARENT" translateX="48.0" translateY="-34.0"/>
                        <Circle fill="#9fb4c2" opacity="0.16" radius="84.0" stroke="TRANSPARENT" translateX="-34.0" translateY="40.0"/>
                        <VBox maxWidth="420.0" spacing="14.0">
                            <children>
                                <Label text="LIVE AUCTION HUB" styleClass="hero-badge"/>
                                <Label text="TAO TAI KHOAN" wrapText="true" styleClass="hero-title"/>
                                <Label text="Hoan tat thong tin ben duoi de tham gia he thong dau gia ngay hom nay."
                                       wrapText="true"
                                       styleClass="hero-subtitle"/>
                            </children>
                        </VBox>
                    </children>
                </StackPane>
                <VBox HBox.hgrow="ALWAYS" prefWidth="520.0" styleClass="card-wrapper">
                    <children>
                        <VBox maxWidth="520.0" prefWidth="520.0" spacing="12.0" styleClass="form-card">
                            <children>
                                <HBox alignment="CENTER_LEFT" spacing="12.0">
                                    <children>
                                        <Button mnemonicParsing="false" onAction="#handleShowHome" styleClass="button home-icon-button">
                                            <graphic>
                                                <SVGPath content="M 12 4 L 3 11 H 5 V 20 H 10 V 14 H 14 V 20 H 19 V 11 H 21 Z"
                                                         styleClass="home-icon-shape"/>
                                            </graphic>
                                        </Button>
                                        <Label text="DANG KY TAI KHOAN" styleClass="section-title"/>
                                    </children>
                                </HBox>
                                <Button mnemonicParsing="false" onAction="#handleBackToLogin" text="QUAY VE DANG NHAP" styleClass="button ghost-button"/>
                                <Label text="Ten dang nhap" styleClass="field-label"/>
                                <TextField fx:id="txtUsername" promptText="Nhap ten dang nhap"/>
                                <Label text="Ho va ten" styleClass="field-label"/>
                                <TextField fx:id="txtFullName" promptText="Nhap ho va ten"/>
                                <Label text="Email" styleClass="field-label"/>
                                <TextField fx:id="txtEmail" promptText="Nhap email"/>
                                <Label text="Mat khau" styleClass="field-label"/>
                                <PasswordField fx:id="txtPassword" promptText="Nhap mat khau"/>
                                <Label text="Nhap lai mat khau" styleClass="field-label"/>
                                <PasswordField fx:id="txtConfirmPassword" onAction="#handleRegister" promptText="Nhap lai mat khau"/>
                                <Label text="Vai tro" styleClass="field-label"/>
                                <ComboBox fx:id="cbRole" prefWidth="476.0" value="BIDDER">
                                    <items>
                                        <FXCollections fx:factory="observableArrayList">
                                            <String fx:value="BIDDER"/>
                                            <String fx:value="SELLER"/>
                                            <String fx:value="ADMIN"/>
                                        </FXCollections>
                                    </items>
                                </ComboBox>
                                <Button mnemonicParsing="false" onAction="#handleRegister" prefWidth="130.0" text="DANG KY" styleClass="button success-button"/>
                            </children>
                        </VBox>
                    </children>
                </VBox>
            </children>
        </HBox>
    </children>
</StackPane>
