<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.Button?>
<?import javafx.scene.control.ComboBox?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.StackPane?>
<?import javafx.scene.layout.VBox?>

<StackPane maxHeight="-Infinity" maxWidth="-Infinity" minHeight="-Infinity" minWidth="-Infinity"
           prefHeight="380.0" prefWidth="480.0"
           fx:controller="userauth.gui.fxml.TopUpDialogController"
           styleClass="dialog-root"
           stylesheets="@auth-theme.css"
           xmlns="http://javafx.com/javafx/21"
           xmlns:fx="http://javafx.com/fxml/1">
    <children>
        <VBox maxWidth="436.0" prefWidth="436.0" spacing="16.0" styleClass="dialog-card">
            <children>
                <Label text="TOP UP WALLET" styleClass="section-title"/>
                <Label fx:id="lblUsername" text="Account: -" styleClass="body-text"/>
                <VBox spacing="10.0">
                    <children>
                        <Label text="Amount" styleClass="field-label"/>
                        <TextField fx:id="txtAmount" promptText="Enter amount to top up"/>
                        <Label text="Payment Method" styleClass="field-label"/>
                        <ComboBox fx:id="cbPaymentMethod" prefWidth="200.0"/>
                    </children>
                </VBox>
                <Label fx:id="lblError" managed="false" text="Error message" visible="false" wrapText="true" styleClass="error-text"/>
                <HBox spacing="10.0" styleClass="dialog-actions">
                    <children>
                        <Button mnemonicParsing="false" onAction="#handleCancel" text="CANCEL" styleClass="button ghost-button"/>
                        <Button mnemonicParsing="false" onAction="#handleSubmit" text="CREATE REQUEST" styleClass="button primary-button"/>
                    </children>
                </HBox>
            </children>
        </VBox>
    </children>
</StackPane>
