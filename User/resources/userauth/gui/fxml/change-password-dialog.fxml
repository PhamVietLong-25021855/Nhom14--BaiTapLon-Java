<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.PasswordField?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.StackPane?>
<?import javafx.scene.layout.VBox?>

<StackPane maxHeight="-Infinity" maxWidth="-Infinity" minHeight="-Infinity" minWidth="-Infinity"
           prefHeight="320.0" prefWidth="440.0"
           fx:controller="userauth.gui.fxml.ChangePasswordDialogController"
           styleClass="page-root"
           stylesheets="@auth-theme.css"
           xmlns="http://javafx.com/javafx/21"
           xmlns:fx="http://javafx.com/fxml/1">
    <children>
        <VBox maxWidth="392.0" prefWidth="392.0" spacing="14.0" styleClass="form-card">
            <children>
                <Label text="DOI MAT KHAU" styleClass="section-title"/>
                <Label fx:id="lblUsername" text="Tai khoan: -" styleClass="body-text"/>
                <VBox spacing="10.0">
                    <children>
                        <Label text="Mat khau hien tai" styleClass="field-label"/>
                        <PasswordField fx:id="txtOldPassword" promptText="Nhap mat khau hien tai"/>
                        <Label text="Mat khau moi" styleClass="field-label"/>
                        <PasswordField fx:id="txtNewPassword" onAction="#handleSubmit" promptText="Nhap mat khau moi"/>
                    </children>
                </VBox>
                <Label fx:id="lblError" managed="false" text="Thong bao loi" visible="false" wrapText="true" styleClass="error-text"/>
                <HBox spacing="10.0" styleClass="dialog-actions">
                    <children>
                        <Button mnemonicParsing="false" onAction="#handleCancel" text="HUY" styleClass="button ghost-button"/>
                        <Button mnemonicParsing="false" onAction="#handleSubmit" text="CAP NHAT" styleClass="button primary-button"/>
                    </children>
                </HBox>
            </children>
        </VBox>
    </children>
</StackPane>
