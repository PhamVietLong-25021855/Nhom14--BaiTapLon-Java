<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.StackPane?>
<?import javafx.scene.layout.VBox?>

<StackPane maxHeight="-Infinity" maxWidth="-Infinity" minHeight="-Infinity" minWidth="-Infinity"
           prefHeight="300.0" prefWidth="450.0"
           fx:controller="userauth.gui.fxml.TextInputDialogController"
           styleClass="dialog-root"
           stylesheets="@auth-theme.css"
           xmlns="http://javafx.com/javafx/21"
           xmlns:fx="http://javafx.com/fxml/1">
    <children>
        <VBox maxWidth="406.0" prefWidth="406.0" spacing="16.0" styleClass="dialog-card">
            <children>
                <Label fx:id="lblTitle" text="INPUT" styleClass="section-title"/>
                <Label fx:id="lblMessage" text="Instruction text" wrapText="true" styleClass="body-text"/>
                <TextField fx:id="txtInput" onAction="#handlePrimary" promptText="Enter value"/>
                <Label fx:id="lblError" managed="false" text="Error message" visible="false" wrapText="true" styleClass="error-text"/>
                <HBox spacing="10.0" styleClass="dialog-actions">
                    <children>
                        <Button fx:id="btnSecondary" mnemonicParsing="false" onAction="#handleSecondary" text="CANCEL" styleClass="button ghost-button"/>
                        <Button fx:id="btnPrimary" mnemonicParsing="false" onAction="#handlePrimary" text="CONFIRM" styleClass="button primary-button"/>
                    </children>
                </HBox>
            </children>
        </VBox>
    </children>
</StackPane>
