<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.StackPane?>
<?import javafx.scene.layout.VBox?>

<StackPane maxHeight="-Infinity" maxWidth="-Infinity" minHeight="-Infinity" minWidth="-Infinity"
           prefHeight="280.0" prefWidth="430.0"
           fx:controller="userauth.gui.fxml.TextInputDialogController"
           styleClass="page-root"
           stylesheets="@auth-theme.css"
           xmlns="http://javafx.com/javafx/21"
           xmlns:fx="http://javafx.com/fxml/1">
    <children>
        <VBox maxWidth="382.0" prefWidth="382.0" spacing="14.0" styleClass="form-card">
            <children>
                <Label fx:id="lblTitle" text="NHAP DU LIEU" styleClass="section-title"/>
                <Label fx:id="lblMessage" text="Noi dung huong dan" wrapText="true" styleClass="body-text"/>
                <TextField fx:id="txtInput" onAction="#handlePrimary" promptText="Nhap gia tri"/>
                <Label fx:id="lblError" managed="false" text="Thong bao loi" visible="false" wrapText="true" styleClass="error-text"/>
                <HBox spacing="10.0" styleClass="dialog-actions">
                    <children>
                        <Button fx:id="btnSecondary" mnemonicParsing="false" onAction="#handleSecondary" text="HUY" styleClass="button ghost-button"/>
                        <Button fx:id="btnPrimary" mnemonicParsing="false" onAction="#handlePrimary" text="XAC NHAN" styleClass="button primary-button"/>
                    </children>
                </HBox>
            </children>
        </VBox>
    </children>
</StackPane>
