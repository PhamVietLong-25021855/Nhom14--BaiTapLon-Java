<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.TextArea?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.StackPane?>
<?import javafx.scene.layout.VBox?>

<StackPane maxHeight="-Infinity" maxWidth="-Infinity" minHeight="-Infinity" minWidth="-Infinity"
           prefHeight="460.0" prefWidth="720.0"
           fx:controller="userauth.gui.fxml.BidHistoryDialogController"
           styleClass="page-root"
           stylesheets="@auth-theme.css"
           xmlns="http://javafx.com/javafx/21"
           xmlns:fx="http://javafx.com/fxml/1">
    <children>
        <VBox maxWidth="672.0" prefWidth="672.0" spacing="14.0" styleClass="form-card">
            <children>
                <Label text="LICH SU BID" styleClass="section-title"/>
                <Label fx:id="lblAuctionName" text="San pham: -" wrapText="true" styleClass="body-text"/>
                <Label fx:id="lblSummary" text="Tong giao dich: 0" styleClass="secondary-text"/>
                <TextArea fx:id="txtHistory" editable="false" prefHeight="300.0" wrapText="true" VBox.vgrow="ALWAYS"/>
                <HBox spacing="10.0" styleClass="dialog-actions">
                    <children>
                        <Button mnemonicParsing="false" onAction="#handleClose" text="DONG" styleClass="button primary-button"/>
                    </children>
                </HBox>
            </children>
        </VBox>
    </children>
</StackPane>
